		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"iab-openrtb": "*",
		"iab-adcom": "*"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"tsup": "^8.0.0",
		"vitest": "^3.0.0",
		"@biomejs/biome": "^1.9.0"
	}
}
