{
	"name": "@trawl/ortb3-trawl",
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
