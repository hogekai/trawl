{
	"name": "@trawl/ortb3-web",
	"version": "0.1.0",
	"type": "module",
	"description": "Browser plugins for @trawl/ortb3",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/hogekai/trawl.git",
		"directory": "packages/ortb3-web"
	},
	"keywords": ["openrtb", "programmatic", "advertising", "consent", "tcf", "topics"],
